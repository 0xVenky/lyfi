# Agent mode: "simulation" (virtual $1M) or "live" (real transactions)
MODE=simulation

# Required for live mode only — generate with: npx tsx -e "import{generatePrivateKey}from'viem/accounts';console.log(generatePrivateKey())"
AGENT_PRIVATE_KEY=

# Optional — LI.FI Composer API key for better rate limits
LIFI_API_KEY=
